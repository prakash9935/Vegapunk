# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-...

# Wazuh Cloud (Option B)
WAZUH_CLOUD_URL=https://my-env.wazuh.cloud
WAZUH_USERNAME=admin
WAZUH_PASSWORD=...
WAZUH_POLL_INTERVAL=60

# Optional: Slack integration
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Optional overrides (defaults shown)
TRIAGE_MODEL=claude-haiku-4-5-20251001
ANALYST_MODEL=claude-sonnet-4-6
TRIAGE_CONFIDENCE_THRESHOLD=0.75
CHUNK_WINDOW_MINUTES=15
MAX_CHUNK_EVENTS=100
LOG_LEVEL=INFO
